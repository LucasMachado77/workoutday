<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WorkOutDay</title>
    <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>
<body>
    <div class="container">
        <h1>Registro de Treinos</h1>
        <form id="treinoForm">
            <div class="dias-container">
                <div class="dia-item">
                    <input type="checkbox" id="segunda" name="dia" value="Segunda-feira">
                    <label for="segunda">Segunda</label>
                </div>
                <div class="dia-item">
                    <input type="checkbox" id="terca" name="dia" value="Terça-feira">
                    <label for="terca">Terça</label>
                </div>
                <div class="dia-item">
                    <input type="checkbox" id="quarta" name="dia" value="Quarta-feira">
                    <label for="quarta">Quarta</label>
                </div>
                <div class="dia-item">
                    <input type="checkbox" id="quinta" name="dia" value="Quinta-feira">
                    <label for="quinta">Quinta</label>
                </div>
                <div class="dia-item">
                    <input type="checkbox" id="sexta" name="dia" value="Sexta-feira">
                    <label for="sexta">Sexta</label>
                </div>
                <div class="dia-item">
                    <input type="checkbox" id="sabado" name="dia" value="Sábado">
                    <label for="sabado">Sábado</label>
                </div>
                <div class="dia-item">
                    <input type="checkbox" id="domingo" name="dia" value="Domingo">
                    <label for="domingo">Domingo</label>
                </div>
            </div>
            <button type="submit">Registrar Treino</button>
        </form>
        <div id="treinoInfo" style="display: none;">
            <h2>Qual foi o seu treino?</h2>
            <input type="text" id="treinoInput" placeholder="Digite seu treino">
            <button onclick="salvarTreino()">Salvar</button>
        </div>
        <div id="resultado"></div>
    </div>
</body>
</html>